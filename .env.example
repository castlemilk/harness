# Database (postgresql:// URL is required by Prisma; actual storage is in DATABASE_DIR)
DATABASE_URL="postgresql://localhost:5432/omega"
DATABASE_DIR="./pglite-data"

# Provider API keys (only needed if you configure cloud providers)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_API_KEY=""
KIMI_API_KEY=""

# Local model endpoint
OLLAMA_BASE_URL="http://localhost:11434"
