{
  "name": "@omega/server",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "DATABASE_URL='postgresql://localhost:5432/omega' DATABASE_DIR='./pglite-data' tsx watch src/index.ts",
    "start": "DATABASE_URL='postgresql://localhost:5432/omega' DATABASE_DIR='./pglite-data' node dist/index.js",
    "test": "DATABASE_URL='postgresql://localhost:5432/omega' DATABASE_DIR='./pglite-data' vitest run"
  },
  "dependencies": {
    "@omega/agent": "workspace:*",
    "@omega/core": "workspace:*",
    "@omega/db": "workspace:*",
    "@omega/providers": "workspace:*",
    "@omega/router": "workspace:*",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
