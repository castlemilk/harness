{
  "name": "@omega/db",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "prebuild": "prisma generate",
    "generate": "prisma generate",
    "migrate": "DATABASE_URL=postgresql://localhost:5432/omega DATABASE_DIR=${DATABASE_DIR:-./pglite-data} tsx src/migrate.ts",
    "migrate:deploy": "DATABASE_URL=postgresql://localhost:5432/omega DATABASE_DIR=${DATABASE_DIR:-./pglite-data} tsx src/migrate.ts",
    "seed": "DATABASE_URL=postgresql://localhost:5432/omega DATABASE_DIR=${DATABASE_DIR:-./pglite-data} tsx src/seed.ts"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.3",
    "@prisma/client": "^5.14.0",
    "pglite-prisma-adapter": "^0.3.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "prisma": "^5.14.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0"
  }
}
